{
  "allowCompoundWords": true,
  "caseSensitive": false,
  "ignorePaths": [
    "**/.git/**",
    "**/.pnpm-lock.json",
    "**/node_modules/**",
    "**/vscode-extension/**",
    ".vscode",
    ".zed",
    "megalinter",
    "megalinter-reports",
    "package-lock.json",
    "report"
  ],
  "language": "en,en-GB",
  "noConfigSearch": true,
  "useGitignore": true,
  "version": "0.2",
  "words": [
    "anthropics",
    "artipacked",
    "bunx",
    "cocogitto",
    "Composio",
    "cump",
    "devenv",
    "direnv",
    "elif",
    "envrc",
    "ggshield",
    "inital",
    "KICS",
    "megalinter",
    "mrdgh",
    "nixfmt",
    "nixpkgs",
    "otbs",
    "oxsecurity",
    "pkgs",
    "prek",
    "pycache",
    "rignore",
    "shfmt",
    "stefanzweifel",
    "tombi",
    "treefmt",
    "venv",
    "yamlfix",
    "zizmor"
  ]
}
